<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.NFC" />
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-feature
        android:name="android.hardware.nfc"
        android:required="false" />

    <application
        android:name=".app.CampusMateApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusMate">
        <provider
            android:name=".data.provider.CampusMateProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false" />

        <receiver
            android:name=".domain.reminder.ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".domain.reminder.BootReminderReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".ui.focus.FocusService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <activity
            android:name=".ui.nfc.NfcReceiveActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CampusMate">
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="application/vnd.campusmate.profile" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.nfc.NfcShareActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.buddy.BuddyDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.buddy.BuddyListActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.profile.ScanQrActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.profile.StudyCardActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.focus.FocusActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.import_.ImportPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.import_.ImportScheduleActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.task.TaskDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.task.TaskEditActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.course.CourseDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.course.CourseEditActivity"
            android:exported="false"
            android:theme="@style/Theme.CampusMate" />
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CampusMate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
