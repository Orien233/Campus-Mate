<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/courseEditRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/campus_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/courseEditAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/campus_surface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/courseEditToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/campus_text_primary"
            app:titleTextColor="@color/campus_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_m">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/course_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courseNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:hint="@string/course_teacher">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courseTeacherInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:hint="@string/course_classroom">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courseClassroomInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/course_weekday"
                android:textColor="@color/campus_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/courseWeekdaySpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/course_time_slot"
                android:textColor="@color/campus_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/courseTimeSlotSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_s"
                    android:layout_weight="1"
                    android:hint="@string/course_start_week">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/courseStartWeekInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_s"
                    android:layout_weight="1"
                    android:hint="@string/course_end_week">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/courseEndWeekInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="18" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/course_week_type"
                android:textColor="@color/campus_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/courseWeekTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/course_color"
                android:textColor="@color/campus_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/courseColorSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:hint="@string/course_note">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/courseNoteInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveCourseButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/action_save"
                app:icon="@drawable/ic_course" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
