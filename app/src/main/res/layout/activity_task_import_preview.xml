<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/taskImportPreviewRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/campus_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/taskImportPreviewAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/campus_surface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/taskImportPreviewToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/campus_text_primary"
            app:titleTextColor="@color/campus_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/taskImportPreviewSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_m"
        android:paddingTop="@dimen/space_m"
        android:paddingEnd="@dimen/space_m"
        android:textColor="@color/campus_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/taskImportPreviewInfoText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_m"
        android:paddingTop="@dimen/space_xs"
        android:paddingEnd="@dimen/space_m"
        android:text="@string/task_import_preview_info"
        android:textColor="@color/campus_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/taskImportPreviewWarningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_m"
        android:paddingTop="@dimen/space_xs"
        android:paddingEnd="@dimen/space_m"
        android:textColor="@color/warning"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/taskDraftRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/space_m" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/campus_surface"
        android:orientation="vertical"
        android:padding="@dimen/space_m">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/importSelectedTasksButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/task_import_selected"
            app:icon="@drawable/ic_import" />
    </LinearLayout>
</LinearLayout>
